# Turso Database (SQLite)
# Crie uma conta gratuita em https://turso.tech
# Depois: turso db create learn-data
# turso db show learn-data --url
# turso db tokens create learn-data
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu-token-aqui

# JWT Secret (gere um valor aleatório)
# Pode usar: openssl rand -base64 32
JWT_SECRET=sua-chave-secreta-aqui
